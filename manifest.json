{
  "manifest_version": 3,
  "name": "notebooks",
  "version": "1.7",
  "description": "Replaces RSS",
  "permissions": ["alarms", "menus", "notifications", "tabs"],

  "browser_specific_settings": {
    "gecko": {
      "id": "@addon-example1"
    }
  },

  "host_permissions": [
      "*://bactra.org/*"
  ],
  "background": {
        "page": "background.xhtml"
  },

  "content_scripts": [{
    "matches": ["https://bactra.org/notebooks/"],
    "css": ["ui/notebooks.css"],  
    "js": ["config.js", "ui/content.js"],
    "run_at": "document_end"
    },{
    "matches": ["https://bactra.org/weblog/"],
    "css": ["ui/notebooks.css"],  
    "js": ["config.js", "ui/content.js"],
    "run_at": "document_end"
  }],

  "action": {
    "default_icon": {
      "16": "icons/brief-icon-16.png",
      "32": "icons/brief-icon-32.png",
      "64": "icons/brief-icon-64.png"
    },
    "default_title": "Fetch Data",
    "default_popup": "popup/settings.html"
  }
}
